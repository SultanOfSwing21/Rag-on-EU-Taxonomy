# Copy to `.env` and fill in the values you need.
# Only the LLM provider you plan to use is required for the Chatbot tab.

# --- Generation evaluation (enabled by default) ---
ENABLE_GENERATION_EVAL=true

# --- OpenAI ---
# OPENAI_API_KEY=sk-...

# --- Azure OpenAI ---
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- AWS Bedrock ---
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=eu-west-1

# --- OpenAI-compatible (Ollama, vLLM, LiteLLM, …) ---
# OPENAI_COMPAT_API_KEY=...
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1

# --- Chatbot defaults (optional) ---
# EU_TAXONOMY_LLM_PROVIDER=openai
# EU_TAXONOMY_LLM_MODEL=gpt-4o-mini
# EU_TAXONOMY_LLM_TEMPERATURE=0.2
# EU_TAXONOMY_LLM_MAX_TOKENS=1024
# EU_TAXONOMY_CHAT_RETRIEVAL_METHOD=hybrid_minilm
# EU_TAXONOMY_CHAT_TOP_K=5
# EU_TAXONOMY_CHAT_CANDIDATE_K=20
